# Contact form — email delivery via SMTP
# Copy this file to .env.local and fill in your values

# Your SMTP provider (e.g. Gmail, Outlook, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-email@gmail.com
SMTP_PASS=your-app-password

# Destination email where contact form messages will be delivered
# This is NEVER exposed to the frontend
CONTACT_EMAIL=your-inbox@gmail.com
